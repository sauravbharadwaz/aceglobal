# Copy to .env.local and fill in from your Supabase project's API settings.
# (Project Settings → API in the Supabase dashboard)

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Only needed if you script admin-only operations server-side. Keep out of client bundles.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Welcome-email integration (Resend)
RESEND_API_KEY=re_YOUR_RESEND_API_KEY
WELCOME_FROM=AceGlobal Team <welcome@aceglobal.ai>
# Shared secret — same value goes into the Supabase Database Webhook's X-Webhook-Secret header.
WELCOME_WEBHOOK_SECRET=any-long-random-string
